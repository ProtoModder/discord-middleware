# ============================================
# DISCORD LLM MIDDLEWARE - CONFIGURATION
# ============================================
# Copy this file to config.yaml and fill in your values

# ----------------------------------------
# DISCORD BOT
# ----------------------------------------
# Get from: https://discord.com/developers/applications
bot_token: "YOUR_DISCORD_BOT_TOKEN"

# ----------------------------------------
# LLM SETTINGS (choose one)
# ----------------------------------------

# Option A: Ollama (local)
llm_endpoint: "http://localhost:11434/api/generate"
llm_api_key: ""

# Option B: OpenAI
# llm_endpoint: "https://api.openai.com/v1/chat/completions"
# llm_api_key: "sk-your-key-here"

# Option C: OpenClaw (forward to existing AI)
# openclaw_url: "http://localhost:8080"

# ----------------------------------------
# SERVER & CHANNELS
# ----------------------------------------
# Enable Developer Mode in Discord to copy IDs
# Right-click server/channel → Copy ID
allowed_servers:
  - "YOUR_SERVER_ID"

allowed_channels:
  - "YOUR_CHANNEL_ID"

# ----------------------------------------
# SECURITY
# ----------------------------------------

# Rate limiting (per user)
rate_limit:
  requests_per_minute: 10
  burst_limit: 20

# Prompt injection patterns (152 security patterns)
# Run middleware with --load-defaults to populate
block_patterns: []

# Content moderation (optional)
moderation:
  enabled: false
  api_key: ""
  block_threshold: 0.9
  flag_threshold: 0.7
